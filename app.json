{
  "expo": {
    "name": "G Todo",
    "slug": "g-todo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "g-todo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.anonymous.gtodo"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/hero.png",
        "backgroundImage": "./assets/images/hero.png",
        "monochromeImage": "./assets/images/hero.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.gtodo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#A8823C",
          "android": {
            "image": "./assets/images/hero.png",
            "dark": {
              "image": "./assets/images/hero.png",
              "backgroundColor": "#C9A84C"
            },
            "imageWidth": 250,
            "resizeMode": "cover",
            "enableFullScreenImage_legacy": true
          }
        }
      ],
      "@clerk/expo",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9fbf385a-a3d6-4108-bbd9-57299ba476d3"
      }
    }
  }
}
